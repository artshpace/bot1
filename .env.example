# =====================================================================
# Shpigotskiy Art Space — Environment Variables
# ---------------------------------------------------------------------
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control (.gitignore must include .env).
#
# Which keys go where:
#   CLIENT-SAFE  — may be embedded in frontend (public info only)
#   SERVER-ONLY  — backend / serverless functions ONLY, never in browser
# =====================================================================

# ---- Telegram Bot ----
# SERVER-ONLY. Get from @BotFather.
TELEGRAM_BOT_TOKEN=

# Admin Telegram chat ID for lead / trial notifications.
# SERVER-ONLY. Get by messaging @userinfobot.
TELEGRAM_ADMIN_CHAT_ID=

# Public bot username (no @). CLIENT-SAFE — shown in "send code to @bot" UI.
TELEGRAM_BOT_USERNAME=shpigotskiy_art_bot

# Webhook secret (random string, used to verify Telegram POST requests).
# SERVER-ONLY.
TELEGRAM_WEBHOOK_SECRET=

# ---- CloudPayments ----
# Public ID — CLIENT-SAFE (used in the browser widget).
CLOUDPAYMENTS_PUBLIC_ID=

# API Secret — SERVER-ONLY (refunds, receipts, webhook verification).
CLOUDPAYMENTS_API_SECRET=

# Test Public ID (for staging/demo mode, no real charges).
CLOUDPAYMENTS_TEST_PUBLIC_ID=pk_test_000000000000000000000000

# ---- Freedom Pay (Фридом Банк) ----
# All credentials SERVER-ONLY.
FREEDOMPAY_MERCHANT_ID=
FREEDOMPAY_SECRET_KEY=
FREEDOMPAY_API_URL=https://api.freedompay.kz/v1

# ---- Kaspi Pay ----
# All credentials SERVER-ONLY.
KASPI_MERCHANT_ID=
KASPI_SECRET_KEY=
KASPI_API_URL=https://kaspi.kz/online

# ---- Meta (Facebook) Ads ----
# Pixel ID — CLIENT-SAFE (embedded in browser pixel snippet).
META_PIXEL_ID=

# Conversions API Token — SERVER-ONLY (server-side event deduplication).
META_CAPI_TOKEN=

# ---- App Config ----
# Base URL of your backend (for webhook registration, redirects, etc.)
APP_URL=https://your-domain.kz

# Secret used to sign internal API requests (e.g., confirmLinkCode webhook).
APP_SECRET=

# Node environment
NODE_ENV=production
